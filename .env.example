# OpenAI (or an OpenAI-compatible proxy)
OPENAI_API_KEY=
# Optional: only set these when using a compatible proxy instead of api.openai.com directly
# (e.g. https://api.aicredits.in/v1 with model "openai/gpt-5-nano").
OPENAI_BASE_URL=
OPENAI_MODEL=

# Meta WhatsApp Business Cloud API
META_WHATSAPP_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
BUSINESS_ID=
PHONE_NUMBER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Trigger.dev v4 (project ref itself goes in trigger.config.ts, not here)
TRIGGER_SECRET_KEY=

# Google Calendar OAuth (see /docs/GOOGLE_CALENDAR_INTEGRATION.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an "Authorized redirect URI" in the Google Cloud Console
# OAuth client. Local dev: http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
# 32-byte key, base64-encoded (generate with: openssl rand -base64 32).
# Encrypts stored Google access/refresh tokens at rest.
GOOGLE_TOKEN_ENCRYPTION_KEY=
# MVP-only shared secret gating /api/auth/google/connect and /status until a
# real staff dashboard exists. Generate a long random value.
ADMIN_SETUP_TOKEN=
